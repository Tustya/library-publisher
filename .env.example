# Копировать в .env и подставить свои значения.
# БД на хосте: для доступа из контейнера используйте host.docker.internal (Docker подставит IP хоста).

DATABASE_URL=postgresql+asyncpg://library_user:YOUR_PASSWORD@host.docker.internal:5432/library
SECRET_KEY=your-long-random-secret-key

# Опционально: разрешённые origins для CORS (через запятую).
# Если фронт и API под одним доменом через nginx — можно не менять.
CORS_ORIGINS=http://localhost,http://127.0.0.1
